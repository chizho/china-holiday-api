{
  "openapi": "3.1.0",
  "info": {
    "title": "China Date Toolkit API",
    "description": "China Date Toolkit API — Provides queries for Chinese public holidays, lunar calendar, Chinese zodiac, Tung Shing (almanac), workday calculations, and 24 solar terms.\n\n## Features\n- **Date Query**: Lunar conversion, zodiac, constellation, Heavenly Stems & Earthly Branches, almanac, solar terms\n- **Holiday Query**: Statutory holidays and adjusted workday schedules\n- **Workday**: Check, calculate, and count working days\n- **Solar Terms**: List of 24 solar terms for a given year\n\n## Authentication\nProduction requests require `X-RapidAPI-Proxy-Secret` header.\n\n## Internationalization\nAll endpoints support `lang` parameter (zh/en/ja/ko/vi/es/fr/de), default is zh.",
    "version": "1.0.0"
  },
  "paths": {
    "/public-china-holiday/date": {
      "get": {
        "tags": [
          "Date"
        ],
        "summary": "Comprehensive Date Query",
        "description": "Returns comprehensive Chinese calendar information for a given date, including lunar date, zodiac, constellation, Heavenly Stems & Earthly Branches, Tung Shing almanac, and solar terms. Supports lang parameter for output language.",
        "operationId": "date_info_public_china_holiday_date_get",
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "公历日期，格式 YYYY-MM-DD，如 2025-10-01",
              "title": "Date"
            },
            "description": "Gregorian date in YYYY-MM-DD format, e.g. 2025-10-01"
          },
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "输出语言: zh/en/ja/ko/vi/es/fr/de",
              "default": "zh",
              "title": "Lang"
            },
            "description": "Output language: zh/en/ja/ko/vi/es/fr/de"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_DateInfoResponse_"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/public-china-holiday/holiday/query": {
      "get": {
        "tags": [
          "Holiday"
        ],
        "summary": "Query Holiday Info by Date",
        "description": "Returns whether the given date is a public holiday, holiday name, and adjusted workday info. Supports lang parameter for output language.",
        "operationId": "query_holiday_public_china_holiday_holiday_query_get",
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "查询日期，格式 YYYY-MM-DD，如 2025-10-01",
              "title": "Date"
            },
            "description": "Gregorian date in YYYY-MM-DD format, e.g. 2025-10-01"
          },
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "输出语言: zh/en/ja/ko/vi/es/fr/de",
              "default": "zh",
              "title": "Lang"
            },
            "description": "Output language: zh/en/ja/ko/vi/es/fr/de"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_HolidayInfo_"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/public-china-holiday/holiday/list": {
      "get": {
        "tags": [
          "Holiday"
        ],
        "summary": "List Holidays by Year",
        "description": "Returns all statutory holidays and adjusted workday arrangements for the given year. Supports lang parameter for output language.",
        "operationId": "list_holidays_api_public_china_holiday_holiday_list_get",
        "parameters": [
          {
            "name": "year",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "description": "年份，如 2025",
              "title": "Year"
            },
            "description": "Year, e.g. 2025"
          },
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "输出语言: zh/en/ja/ko/vi/es/fr/de",
              "default": "zh",
              "title": "Lang"
            },
            "description": "Output language: zh/en/ja/ko/vi/es/fr/de"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_HolidayListResponse_"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/public-china-holiday/workday": {
      "get": {
        "tags": [
          "Workday"
        ],
        "summary": "Check Workday",
        "description": "Returns whether the given date is a working day and the reason (e.g., public holiday, weekend, adjusted workday). Supports lang parameter for output language.",
        "operationId": "check_public_china_holiday_workday_get",
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "公历日期，格式 YYYY-MM-DD，如 2025-10-01",
              "title": "Date"
            },
            "description": "Gregorian date in YYYY-MM-DD format, e.g. 2025-10-01"
          },
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "输出语言: zh/en/ja/ko/vi/es/fr/de",
              "default": "zh",
              "title": "Lang"
            },
            "description": "Output language: zh/en/ja/ko/vi/es/fr/de"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_WorkdayCheckResponse_"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/public-china-holiday/workday/calculate": {
      "get": {
        "tags": [
          "Workday"
        ],
        "summary": "Workday Calculation",
        "description": "Two modes: ① Pass workdays to calculate a target date. ② Pass end_date to count working days. Supports lang parameter for output language.",
        "operationId": "calculate_public_china_holiday_workday_calculate_get",
        "parameters": [
          {
            "name": "start_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "起始日期，格式 YYYY-MM-DD",
              "title": "Start Date"
            },
            "description": "Start date in YYYY-MM-DD format"
          },
          {
            "name": "workdays",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "推算模式：要增加的工作日天数（正数=未来，负数=过去）",
              "title": "Workdays"
            },
            "description": "Mode 1: Number of working days to add (positive=future, negative=past)"
          },
          {
            "name": "end_date",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "计数模式：结束日期，格式 YYYY-MM-DD",
              "title": "End Date"
            },
            "description": "Mode 2: End date in YYYY-MM-DD format"
          },
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "输出语言: zh/en/ja/ko/vi/es/fr/de",
              "default": "zh",
              "title": "Lang"
            },
            "description": "Output language: zh/en/ja/ko/vi/es/fr/de"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_WorkdayCalcResponse_"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
