    "/public-china-holiday/workday/calculate": {
      "get": {
        "tags": [
          "工作日 Workday"
        ],
        "summary": "工作日计算",
        "description": "两种模式：① 传入 workdays 推算目标日期 ② 传入 end_date 计算工作日数量。支持 lang 参数切换输出语言。",
        "operationId": "calculate_public_china_holiday_workday_calculate_get",
        "parameters": [
          {
            "name": "start_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "起始日期，格式 YYYY-MM-DD",
              "title": "Start Date"
            },
            "description": "起始日期，格式 YYYY-MM-DD"
          },
          {
            "name": "workdays",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "推算模式：要增加的工作日天数（正数=未来，负数=过去）",
              "title": "Workdays"
            },
            "description": "推算模式：要增加的工作日天数（正数=未来，负数=过去）"
          },
          {
            "name": "end_date",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "计数模式：结束日期，格式 YYYY-MM-DD",
              "title": "End Date"
            },
            "description": "计数模式：结束日期，格式 YYYY-MM-DD"
          },
